## Backend (Laravel)
## Copiá este archivo a `backend/.env` y ajustá lo necesario.
##
## Para DEV local podés usar SQLite (recomendado para clonar rápido):
##   DB_CONNECTION=sqlite
##   (y crear el archivo `backend/database/database.sqlite`)
##
## O MySQL (XAMPP):
##   DB_CONNECTION=mysql
##   DB_HOST=127.0.0.1
##   DB_PORT=3306
##   DB_DATABASE=jobbrige
##   DB_USERNAME=root
##   DB_PASSWORD=

APP_NAME=Jobbrige
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/jobbrige/backend/public

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000

# CORS (separado por coma). Debe incluir donde corre el frontend (CRA suele ser 3000).
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000


